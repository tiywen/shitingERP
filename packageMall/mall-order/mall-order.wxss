.order-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.order-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.goods-line {
  display: flex;
  align-items: center;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.goods-thumb {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.goods-ph-tea {
  background: linear-gradient(160deg, #f0e6d8 0%, #d4c4a8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.thumb-t {
  font-size: 48rpx;
  font-weight: 700;
  color: #5c4a32;
}

.goods-meta {
  flex: 1;
  margin-left: 24rpx;
}

.goods-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
}

.goods-spec {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #999;
}

.qty-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 24rpx;
}

.qty-label {
  font-size: 28rpx;
  color: #333;
}

.qty-ctrl {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.qty-btn {
  width: 64rpx;
  height: 64rpx;
  line-height: 60rpx;
  padding: 0;
  margin: 0;
  font-size: 36rpx;
  color: #333;
  background: #f5f5f5;
  border-radius: 8rpx;
  border: none;
}

.qty-btn::after {
  border: none;
}

.qty-num {
  font-size: 32rpx;
  font-weight: 600;
  min-width: 48rpx;
  text-align: center;
}

.field-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.field-row-block {
  flex-direction: column;
  align-items: stretch;
}

.field-label {
  width: 140rpx;
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
}

.field-row-block .field-label {
  width: auto;
  margin-bottom: 12rpx;
}

.field-input {
  flex: 1;
  font-size: 28rpx;
}

.field-textarea {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  padding: 16rpx;
  background: #fafafa;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.order-tip {
  padding: 16rpx 8rpx;
  font-size: 22rpx;
  color: #999;
  line-height: 1.6;
}

.order-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
  gap: 24rpx;
}

.bar-total {
  flex: 1;
}

.total-label {
  font-size: 24rpx;
  color: #999;
  margin-right: 8rpx;
}

.total-price {
  font-size: 40rpx;
  font-weight: 700;
  color: #e64545;
}

.bar-submit {
  width: 260rpx;
  height: 88rpx;
  line-height: 88rpx;
  margin: 0;
  padding: 0;
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(90deg, #1a5f4a 0%, #2d8a6e 100%);
  border-radius: 44rpx;
  border: none;
}

.bar-submit::after {
  border: none;
}
