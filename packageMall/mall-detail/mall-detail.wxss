.detail-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.detail-swiper {
  height: 560rpx;
  background: #fff;
}

.detail-slide-img {
  width: 100%;
  height: 100%;
}

.detail-slide-ph {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.ph-a {
  background: linear-gradient(160deg, #f5ebe0 0%, #d4c4a8 100%);
}

.ph-b {
  background: linear-gradient(160deg, #e8f0eb 0%, #b8d4c4 100%);
}

.detail-ph-main {
  font-size: 80rpx;
  font-weight: 700;
  color: #4a3f2e;
}

.detail-ph-sub {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #6b5d4a;
}

.detail-indicator {
  text-align: center;
  font-size: 22rpx;
  color: #999;
  padding: 12rpx 0;
  background: #fff;
}

.detail-card {
  margin: 20rpx 24rpx;
  padding: 28rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.detail-price-row {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

.detail-price {
  font-size: 48rpx;
  font-weight: 700;
  color: #e64545;
}

.yen {
  font-size: 28rpx;
}

.detail-unit {
  font-size: 26rpx;
  color: #999;
  margin-left: 6rpx;
}

.detail-sales {
  margin-left: auto;
  font-size: 22rpx;
  color: #ccc;
}

.detail-name {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
}

.detail-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #888;
}

.detail-tags {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.detail-tag {
  padding: 6rpx 16rpx;
  font-size: 22rpx;
  color: #1a5f4a;
  background: #e8f5f0;
  border-radius: 8rpx;
}

.block-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #eee;
}

.spec-row {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 26rpx;
}

.spec-label {
  width: 140rpx;
  color: #999;
  flex-shrink: 0;
}

.spec-value {
  flex: 1;
  color: #333;
  line-height: 1.5;
}

.detail-desc {
  font-size: 28rpx;
  color: #555;
  line-height: 1.75;
}

.detail-bottom-spacer {
  height: 24rpx;
}

.detail-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  gap: 20rpx;
  z-index: 100;
}

.safe-bottom {
  box-sizing: border-box;
}

.bar-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: none;
  margin: 0;
  padding: 0;
}

.bar-btn::after {
  border: none;
}

.bar-cart {
  background: #fff1e8;
  color: #c45c26;
  border: 2rpx solid #e8a87c;
}

.bar-buy {
  background: linear-gradient(90deg, #e64545 0%, #ff6b35 100%);
  color: #fff;
  font-weight: 600;
}
