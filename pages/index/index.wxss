.section-title {
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 24rpx;
  color: var(--text-color);
}

.date-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.picker-cell {
  flex: 1;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.picker-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.picker-value {
  font-size: 28rpx;
  color: var(--primary-color);
  font-weight: 500;
}

.date-divider {
  margin: 0 24rpx;
  font-size: 26rpx;
  color: var(--text-placeholder);
}

.nights-tip {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: var(--primary-color);
  font-weight: 500;
}

.room-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.room-item:last-child {
  border-bottom: none;
}

.room-main {
  flex: 1;
}

.room-name {
  font-size: 30rpx;
  color: var(--text-color);
  font-weight: 500;
}

.room-meta {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.meta-divider {
  margin: 0 12rpx;
  color: var(--text-placeholder);
}

.room-price {
  text-align: right;
  margin-left: 24rpx;
}

.room-price .price-num {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--primary-color);
}

.room-price .price-unit {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.empty-tip {
  text-align: center;
  padding: 48rpx;
  color: var(--text-placeholder);
}
