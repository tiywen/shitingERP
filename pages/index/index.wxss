.home-wrap {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 48rpx 32rpx calc(140rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #e8f5f0 0%, #f5f5f5 45%);
}

.home-brand {
  text-align: center;
  padding: 40rpx 0 56rpx;
}

.home-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #1a5f4a;
  letter-spacing: 4rpx;
}

.home-sub {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #666;
}

.home-actions {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
}

.home-card {
  flex: 1;
  min-height: 320rpx;
  padding: 40rpx 28rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(26, 95, 74, 0.12);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.home-card-room {
  background: linear-gradient(160deg, #ffffff 0%, #e8f4ef 100%);
  border: 2rpx solid rgba(26, 95, 74, 0.15);
}

.home-card-mall {
  background: linear-gradient(160deg, #ffffff 0%, #fff8f0 100%);
  border: 2rpx solid rgba(255, 107, 53, 0.2);
}

.home-card-icon {
  font-size: 72rpx;
  margin-bottom: 20rpx;
}

.home-card-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.home-card-desc {
  font-size: 24rpx;
  color: #888;
  text-align: center;
  line-height: 1.5;
}

.home-tip {
  margin-top: 48rpx;
  text-align: center;
  font-size: 22rpx;
  color: #aaa;
  padding: 0 16rpx;
}
