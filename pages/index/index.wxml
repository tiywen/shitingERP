<view class="home-wrap">
  <view class="home-brand">
    <text class="home-title">石亭书院</text>
    <text class="home-sub">欢迎光临</text>
  </view>

  <view class="home-actions">
    <view class="home-card home-card-room" bindtap="goRoom">
      <view class="home-card-icon">🏨</view>
      <text class="home-card-title">订房</text>
      <text class="home-card-desc">选择日期 · 浏览房型 · 在线预订</text>
    </view>
    <view class="home-card home-card-mall" bindtap="goMall">
      <view class="home-card-icon">🛒</view>
      <text class="home-card-title">商城</text>
      <text class="home-card-desc">精选好物 · 礼盒伴手礼</text>
    </view>
  </view>

  <view class="home-tip">演示商城暂未对接支付，下单仅为流程体验</view>
</view>
