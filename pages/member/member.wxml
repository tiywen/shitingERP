<view class="container tab-page">
  <view class="card user-status">
    <view class="status-row">
      <text class="status-label">登录状态</text>
      <text class="status-value {{isLoggedIn ? 'active' : ''}}">{{isLoggedIn ? '已登录' : '未登录'}}</text>
    </view>
    <view class="status-row">
      <text class="status-label">会员种类</text>
      <text class="status-value">{{roleLabel}}</text>
    </view>
    <view wx:if="{{isLoggedIn && userName}}" class="status-row">
      <text class="status-label">昵称/手机</text>
      <text class="status-value">{{userName}}</text>
    </view>
    <view wx:if="{{isLoggedIn}}" class="status-row">
      <button class="btn-logout" bindtap="onLogout">退出登录</button>
    </view>
  </view>

  <!-- 未登录：登录区域 -->
  <view wx:if="{{!isLoggedIn}}" class="card login-card">
    <view class="login-title">手机号登录</view>
    <view class="login-sub">支持微信一键授权或验证码登录，未注册用户将自动注册</view>

    <button
      class="btn-wechat-phone"
      open-type="getPhoneNumber"
      bindgetphonenumber="onWechatPhone"
    >微信手机号一键登录</button>

    <view class="login-divider">或</view>

    <view class="login-form">
      <input
        class="input"
        type="number"
        maxlength="11"
        placeholder="请输入手机号"
        value="{{form.phone}}"
        data-field="phone"
        bindinput="onInput"
      />
      <view class="code-row">
        <input
          class="input code-input"
          type="number"
          maxlength="6"
          placeholder="验证码"
          value="{{form.code}}"
          data-field="code"
          bindinput="onInput"
        />
        <button class="btn-code" disabled="{{countdown > 0}}" bindtap="onSendCode">
          {{countdown > 0 ? countdown + 's后重发' : '获取验证码'}}
        </button>
      </view>
      <button class="btn-verify" bindtap="onVerifyCode">验证码登录</button>
    </view>
  </view>

  <view class="card list" wx:if="{{isLoggedIn}}">
    <view class="list-item" bindtap="goWorkOrders">
      <text>查看工单状态</text>
      <text class="arrow">›</text>
    </view>
    <view class="list-item" bindtap="goOrders">
      <text>查看订单</text>
      <text class="arrow">›</text>
    </view>
    <view class="list-item" bindtap="goMyBookings">
      <text>我的预约</text>
      <text class="arrow">›</text>
    </view>
    <view class="list-item" bindtap="goInvoices">
      <text>查看发票</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <view wx:if="{{isLoggedIn}}" class="card">
    <view class="mall-entry" bindtap="goMall">
      <text class="mall-title">商城入口</text>
      <text class="mall-desc">精选好物</text>
      <text class="arrow">›</text>
    </view>
  </view>
</view>
