.user-status {
  margin-bottom: 24rpx;
}

.login-card {
  margin-bottom: 24rpx;
}

.login-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.login-sub {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 32rpx;
}

.btn-wechat-phone {
  background: #07c160;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 28rpx;
  font-size: 30rpx;
}

.login-divider {
  text-align: center;
  color: var(--text-placeholder);
  font-size: 26rpx;
  margin: 28rpx 0;
}

.login-form .input {
  border: 1rpx solid var(--border-color);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}

.code-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.code-input {
  flex: 1;
}

.btn-code {
  flex-shrink: 0;
  padding: 24rpx 28rpx;
  font-size: 26rpx;
  background: #f5f5f5;
  color: var(--text-color);
  border: 1rpx solid var(--border-color);
  border-radius: 12rpx;
}

.btn-code[disabled] {
  color: var(--text-placeholder);
}

.btn-verify {
  background: var(--primary-color);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 28rpx;
  font-size: 30rpx;
}

.btn-logout {
  margin-top: 16rpx;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: var(--text-secondary);
  background: transparent;
  border: none;
}

.status-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.status-row:first-child {
  padding-top: 0;
}

.status-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.status-value {
  font-size: 28rpx;
  color: var(--text-color);
}

.status-value.active {
  color: var(--primary-color);
  font-weight: 500;
}

.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.list-item:last-child {
  border-bottom: none;
}

.arrow {
  font-size: 36rpx;
  color: var(--text-placeholder);
}

.mall-entry {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
}

.mall-title {
  font-size: 32rpx;
  font-weight: 500;
}

.mall-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-left: 16rpx;
  flex: 1;
}

.mall-entry .arrow {
  margin-left: auto;
}
