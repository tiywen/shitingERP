.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.list-item:last-child {
  border-bottom: none;
}

.arrow {
  font-size: 36rpx;
  color: var(--text-placeholder);
}

.mall-entry {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
}

.mall-title {
  font-size: 32rpx;
  font-weight: 500;
}

.mall-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-left: 16rpx;
  flex: 1;
}

.mall-entry .arrow {
  margin-left: auto;
}
