.form-item {
  margin-bottom: 32rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.input {
  width: 100%;
  min-height: 80rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  line-height: 40rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.input[disabled] {
  color: var(--text-placeholder);
}

.textarea {
  width: 100%;
  min-height: 240rpx;
  padding: 24rpx;
  font-size: 28rpx;
  line-height: 1.5;
  background: #f8f9fa;
  border-radius: 12rpx;
  box-sizing: border-box;
  display: block;
}

.picker-value {
  padding: 24rpx;
  font-size: 28rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  color: var(--text-color);
}

.btn-submit {
  margin-top: 48rpx;
  background: var(--primary-color);
  color: #fff;
  font-size: 32rpx;
  border-radius: 12rpx;
}
