<view class="container">
  <view wx:if="{{loading}}" class="loading-wrap">
    <text>加载中...</text>
  </view>
  <view wx:elif="{{empty}}" class="empty-wrap">
    <text class="empty-tip">暂无餐厅预约</text>
  </view>
  <view wx:else class="list">
    <view
      wx:for="{{list}}"
      wx:key="id"
      class="card"
    >
      <view class="row">
        <text class="date">{{item.date}}</text>
        <text class="status-tag status-{{item.status}}">{{item.statusLabel || (item.status === 'pending' ? '已提交' : (item.status === 'confirmed' ? '已确认' : item.status))}}</text>
      </view>
      <view class="row label">
        {{item.mealLabel}} · {{item.bookingTypeLabel}} · {{item.timeSlot}} · {{item.headcount}}人
      </view>
      <view wx:if="{{item.remark}}" class="remark">{{item.remark}}</view>
    </view>
  </view>
</view>
