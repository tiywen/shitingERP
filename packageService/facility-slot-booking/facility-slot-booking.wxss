.container {
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.tip {
  font-size: 26rpx;
  color: var(--text-secondary, #666);
  margin-bottom: 24rpx;
  line-height: 1.5;
}

.loading-wrap,
.error-wrap {
  padding: 60rpx 0;
  text-align: center;
  color: var(--text-secondary, #666);
}

.error-wrap {
  color: #d48806;
}

.empty-wrap {
  padding: 40rpx 24rpx;
  text-align: left;
  font-size: 28rpx;
  line-height: 1.6;
  color: #666;
  background: #f7f7f7;
  border-radius: 12rpx;
}

.grid-wrap {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.day-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.day-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-color, #333);
  margin-bottom: 20rpx;
}

.slots {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.slot-cell {
  width: calc(25% - 12rpx);
  min-width: 140rpx;
  padding: 20rpx 16rpx;
  text-align: center;
  border-radius: 12rpx;
  border: 2rpx solid #e8e8e8;
  background: #fafafa;
}

.slot-cell.disabled {
  background: #f0f0f0;
  color: #999;
  border-color: #eee;
}

.slot-cell.selected {
  background: rgba(26, 95, 74, 0.12);
  border-color: var(--primary-color, #1a5f4a);
  color: var(--primary-color, #1a5f4a);
}

.slot-label {
  font-size: 24rpx;
  display: block;
}

.slot-tag {
  font-size: 20rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

.summary {
  margin-top: 32rpx;
  font-size: 26rpx;
  color: var(--text-secondary, #666);
}

.summary-item {
  display: inline-block;
  margin-right: 12rpx;
}

.btn-submit {
  margin-top: 48rpx;
  background: var(--primary-color, #1a5f4a);
  color: #fff;
  font-size: 32rpx;
  border-radius: 12rpx;
}

.btn-submit[disabled] {
  background: #ccc;
  color: #fff;
}
