// 石亭 ERP 数据库模型
// 使用 MySQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============ 用户 ============
// 业主、院友、访客统一用 role 区分
model User {
  id         Int      @id @default(autoincrement())
  openid     String?  @unique // 微信 openid
  nickname   String?  // 微信昵称
  role       String   @default("visitor") // owner | member | visitor
  name       String?  // 姓名（代号）
  phone      String?  // 手机号（登录用）

  // 业主字段
  ownerCode   String?  // 业主识别编号
  houseNumber String?  // 关联户号

  // 院友字段
  memberCode String?  // 会员编号
  ownerId    Int?     // 关联业主
  owner      User?    @relation("MemberToOwner", fields: [ownerId], references: [id])
  members    User[]   @relation("MemberToOwner")

  // 访客字段
  visitorCode String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders          Order[]
  workOrders      WorkOrder[]
  facilityBookings FacilityBooking[]
  invoices        Invoice[]
}

// ============ 房型 ============
model RoomType {
  id           Int      @id @default(autoincrement())
  name         String   // 房型名称
  bedType      String   @default("") // 床型
  maxOccupancy Int      @default(2) // 可住人数
  price        Decimal  @db.Decimal(10, 2) // 原价/晚
  discountPrice Decimal @db.Decimal(10, 2) // 业主/院友折扣价/晚

  // Excel 导入字段
  roomNo              String?  // 房号
  typeName            String?  @map("type_name") // 房型
  roomName            String?  @map("room_name") // 客房名称
  memberWeekdayPrice  Decimal? @db.Decimal(10, 2) @map("member_weekday_price") // 会员平日价
  memberWeekendPrice  Decimal? @db.Decimal(10, 2) @map("member_weekend_price") // 会员假日价
  platformWeekdayPrice Decimal? @db.Decimal(10, 2) @map("platform_weekday_price") // 平台平日价
  platformWeekendPrice Decimal? @db.Decimal(10, 2) @map("platform_weekend_price") // 平台假日价
  specialHolidayPrice Decimal? @db.Decimal(10, 2) @map("special_holiday_price") // 特殊节假日
  platformPromoWeekday Decimal? @db.Decimal(10, 2) @map("platform_promo_weekday") // 平台推广平日价
  platformPromoWeekend Decimal? @db.Decimal(10, 2) @map("platform_promo_weekend") // 平台推广假日价
  originalPrice       Decimal? @db.Decimal(10, 2) @map("original_price") // 原价
  descriptionZh       String?  @db.Text @map("description_zh") // 房型说明(中)
  descriptionEn       String?  @db.Text @map("description_en") // 房型说明(英)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders   Order[]
  rooms    Room[]
  images   RoomTypeImage[]
}

// ============ 房型图（每房型最多 10 张） ============
model RoomTypeImage {
  id         Int      @id @default(autoincrement())
  roomTypeId Int
  roomType   RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  path       String   // 存储路径，如 room-types/1/xxx.jpg
  sortOrder  Int      @default(0) @map("sort_order")

  createdAt DateTime @default(now())

  @@map("room_type_images")
}

// ============ 物理房间（用于工单关联） ============
model Room {
  id          Int      @id @default(autoincrement())
  roomNo      String   // 房间号
  roomTypeId  Int
  roomType    RoomType @relation(fields: [roomTypeId], references: [id])
  houseNumber String?  // 关联户号（业主房间）

  workOrders WorkOrder[]
}

// ============ 订单 ============
model Order {
  id            Int      @id @default(autoincrement())
  userId        Int?
  user          User?    @relation(fields: [userId], references: [id])
  roomTypeId    Int
  roomType      RoomType @relation(fields: [roomTypeId], references: [id])

  checkinDate   DateTime @db.Date
  checkoutDate  DateTime @db.Date
  nights        Int
  pricePerNight Decimal  @db.Decimal(10, 2)
  totalAmount   Decimal  @db.Decimal(10, 2)

  guestName     String
  guestPhone    String
  arriveTime    String?  // 预计到店时间
  remark        String?  @db.Text

  status        String   @default("pending") // pending | confirmed | checked_in | checked_out | cancelled

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices Invoice[]

  @@map("orders")
}

// ============ 工单 ============
model WorkOrder {
  id      Int     @id @default(autoincrement())
  userId  Int
  user    User    @relation(fields: [userId], references: [id])
  roomId  Int?    // 可为空，有多个关联房间时可选择
  room    Room?   @relation(fields: [roomId], references: [id])

  type        String  // heating | ventilation | repair | delivery | other
  status      String  @default("submitted") // submitted | in_progress | completed
  roomKind    String? // 房间种类（客厅、一楼卧室等）
  content     String? @db.Text // 服务要求描述
  adminRemark String? @db.Text // 管理备注（如：x月x日已处理）

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ 设施 ============
model Facility {
  id          Int     @id @default(autoincrement())
  name        String  // 停车场、餐厅、K歌房、洗衣房、匹克球场
  type        String  // static | booking
  description String? @db.Text // 静态介绍内容
  bookingCapacity Int? @map("booking_capacity") // 餐厅预约每餐人数上限，仅餐厅使用，默认 40

  bookings FacilityBooking[]
}

// ============ 设施预约 ============
model FacilityBooking {
  id         Int      @id @default(autoincrement())
  facilityId Int
  facility   Facility @relation(fields: [facilityId], references: [id])
  userId     Int
  user       User     @relation(fields: [userId], references: [id])

  bookingDate DateTime @db.Date
  timeSlot    String   // 时间段，如 "08:00"

  // 餐厅预约专用：餐次、预约类型、人数
  mealPeriod  String?  @map("meal_period")  // breakfast | lunch | dinner
  bookingType String?  @map("booking_type")  // table | individual 桌餐 | 单人餐
  headcount   Int?     @map("headcount")     // 人数（桌餐≥10，单人餐≥1）
  remark      String?  @db.Text              // 备注

  status     String   @default("pending") // pending | confirmed | cancelled

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ 发票 ============
model Invoice {
  id      Int     @id @default(autoincrement())
  orderId Int?
  order   Order?  @relation(fields: [orderId], references: [id])
  userId  Int
  user    User    @relation(fields: [userId], references: [id])

  amount  Decimal @db.Decimal(10, 2)
  status  String  @default("pending")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ 固定资产 ============
model FixedAsset {
  id               Int       @id @default(autoincrement())
  serialNo         Int?      @map("serial_no")         // 序号
  category         String?   @map("category")          // 资产类别
  name             String?   @map("name")               // 资产名称
  specification    String?   @map("specification")     // 规格型号
  quantity         Int?      @map("quantity")          // 数量
  unit             String?   @map("unit")              // 单位
  price            Decimal?  @db.Decimal(12, 2) @map("price") // 价格
  purchaseTime     DateTime? @db.Date @map("purchase_time")    // 采购时间
  serviceLife      String?   @map("service_life")      // 使用年限
  usageStatus      String?   @map("usage_status")     // 使用情况
  productSerialNo  String?   @map("product_serial_no") // 产品序列号
  productAppearance String?  @db.Text @map("product_appearance") // 产品外观（预留，实际用 images）
  storageLocation  String?   @map("storage_location") // 存放地点
  dailyManager     String?   @map("daily_manager")    // 日常管理人
  remark           String?   @db.Text @map("remark")  // 备注

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  images    FixedAssetImage[]

  @@map("fixed_assets")
}

// ============ 固定资产产品外观图 ============
model FixedAssetImage {
  id           Int        @id @default(autoincrement())
  fixedAssetId Int        @map("fixed_asset_id")
  fixedAsset   FixedAsset @relation(fields: [fixedAssetId], references: [id], onDelete: Cascade)
  path         String     // 存储路径，如 fixed-assets/1/xxx.jpg
  sortOrder    Int        @default(0) @map("sort_order")

  createdAt DateTime @default(now())

  @@map("fixed_asset_images")
}
